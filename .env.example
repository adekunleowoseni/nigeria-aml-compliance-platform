# Database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secure_password

POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/aml_platform

# Audit (append-only audit_events table + hash chain; set key to enable POST /api/v1/audit/event)
AUDIT_TRAIL_BACKEND=postgres
AUDIT_INTERNAL_API_KEY=

# FTR (CBN wire / remittance reporting)
FTR_THRESHOLD_NGN=1000000
FTR_THRESHOLD_USD=1000
FTR_USD_NGN_RATE=1550
FTR_RETENTION_YEARS=5
FTR_AUTO_SCAN_INTERVAL_HOURS=24
CBN_FTR_SUBMIT_MODE=stub
CBN_FTR_API_URL=
CBN_FTR_FILE_DROP_DIR=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TRANSACTIONS_TOPIC=transactions
KAFKA_ALERTS_TOPIC=alerts
KAFKA_MODEL_UPDATES_TOPIC=model-updates

# Redis
REDIS_URL=redis://redis:6379/0

# Celery (retention daily job). Broker DB 1 avoids clashing with app cache on /0.
CELERY_BROKER_URL=redis://redis:6379/1
# Shared secret: Celery POSTs to the API so in-memory alerts/transactions/reports are purged in-process.
RETENTION_INTERNAL_API_KEY=
# Docker: http://backend:8000/api/v1/admin/retention/run-now — local: http://localhost:8002/api/v1/admin/retention/run-now
RETENTION_RUN_NOW_URL=
RETENTION_HARD_PURGE_GRACE_DAYS=30
# In-process retention loop (hours); use 0 when Celery Beat triggers run-now only.
RETENTION_EMBEDDED_RUN_INTERVAL_HOURS=0
# Reference lists (sanctions / PEP / adverse media): JSON or XML upload + fuzzy rescreen of all customers.
# Celery Beat can POST run-now; otherwise the API runs an embedded loop every N hours (default 24).
REFERENCE_LISTS_INTERNAL_API_KEY=
# Docker: http://backend:8000/api/v1/admin/reference-lists/screening/run-now
REFERENCE_LISTS_RUN_NOW_URL=
REFERENCE_LISTS_FUZZY_THRESHOLD=82
REFERENCE_LISTS_EMBEDDED_RUN_INTERVAL_HOURS=24
# MI email schedules (Celery → API). Defaults to same internal key as retention if MI_SCHEDULE_INTERNAL_API_KEY is empty.
MI_TICK_URL=http://backend:8000/api/v1/reports/mi/tick-schedules
MI_SCHEDULE_INTERNAL_API_KEY=
# Optional absolute API base for Board pack PDF/Word pre-signed URLs in emails (e.g. https://aml.bank.com)
PUBLIC_API_BASE_URL=
MI_PDF_DOWNLOAD_TTL_SECONDS=900

# Security
JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# NFIU
NFIU_API_URL=https://portal.fiu.gov.ng/api
NFIU_API_KEY=your-api-key
NFIU_CLIENT_CERT_PATH=
NFIU_PRIVATE_KEY_PATH=

# ML Model
MODEL_PATH=/app/models/gnn_model.pt
MODEL_BATCH_SIZE=32
MODEL_CONFIDENCE_THRESHOLD=0.7

# Federated Learning
FL_SERVER_ADDRESS=0.0.0.0:8080
FL_INSTITUTION_ID=your-institution-id
FL_MIN_CLIENTS=3

# Application
APP_ENV=development
LOG_LEVEL=INFO
ENABLE_SWAGGER=true
LLM_PROVIDER=gemini
# Set true only for local API testing without login (development + no Bearer).
ALLOW_ANONYMOUS_DEV=false
# Default admin UI login (change password after first login in production):
# admin@admin.com / 12345678

# SMTP (EDD emails to customers, CCO pre-escalation notices)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
# Required for automatic CCO emails on escalation (with SMTP). CCO can always use in-app CCO review without this.
CCO_EMAIL=

# Optional workflow shortcuts (default false). Admins can also change these live under Settings → Compliance workflow.
# CCO_AUTO_APPROVE_OTC_REPORTING=false
# CCO_AUTO_APPROVE_STR_ON_ESCALATION=false

# Optional: PNG/JPG on the API server — embedded as Chief Compliance Officer signature in SAR Word export
CCO_SIGNATURE_IMAGE_PATH=

# OpenSanctions API (online screening; optional key if your deployment requires auth)
OPENSANCTIONS_API_KEY=

# Real-time transaction screening (rules + optional LLM on ingest). KYC fields: customer_segment,
# expected_annual_turnover, customer_remarks on aml_customer_kyc (or transaction metadata).
ANOMALY_THRESHOLD=0.6
AML_HUGE_INFLOW_INDIVIDUAL_NGN=5000000
AML_HUGE_INFLOW_CORPORATE_NGN=10000000
AML_TURNOVER_EXCEEDS_EXPECTED_RATIO=1.0
AML_REALTIME_LLM_SCREENING=true
# LLM selects red-flag catalog rule_code from remarks + activity; adds RF-AI-EXT-* if no catalog rule fits.
AML_RED_FLAG_LLM_MATCHING=true
AML_RED_FLAG_LLM_MAX_CATALOG_RULES=55
# Run same LLM pass when rebuilding alert snapshots (default false — doubles LLM cost per view).
AML_RED_FLAG_LLM_ON_SNAPSHOT=false
# Log LLM red-flag JSON to aml_red_flag_ai_observations for analytics / manual rule tuning.
AML_RED_FLAG_AI_OBSERVATION_LOG=false

# Frontend
VITE_API_URL=
VITE_PROXY_TARGET=http://localhost:8000

