# Database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secure_password

POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/aml_platform

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TRANSACTIONS_TOPIC=transactions
KAFKA_ALERTS_TOPIC=alerts
KAFKA_MODEL_UPDATES_TOPIC=model-updates

# Redis
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# NFIU
NFIU_API_URL=https://portal.fiu.gov.ng/api
NFIU_API_KEY=your-api-key
NFIU_CLIENT_CERT_PATH=
NFIU_PRIVATE_KEY_PATH=

# ML Model
MODEL_PATH=/app/models/gnn_model.pt
MODEL_BATCH_SIZE=32
MODEL_CONFIDENCE_THRESHOLD=0.7

# Federated Learning
FL_SERVER_ADDRESS=0.0.0.0:8080
FL_INSTITUTION_ID=your-institution-id
FL_MIN_CLIENTS=3

# Application
APP_ENV=development
LOG_LEVEL=INFO
ENABLE_SWAGGER=true

# Frontend
VITE_API_URL=
VITE_PROXY_TARGET=http://localhost:8000

